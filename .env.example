# RepoSense API keys (all optional in low-cost mode)
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Runtime
EXECUTION_MODE=autonomous
LOW_COST_MODE=true
USE_LOCAL_MODELS=false
LOCAL_MODEL=deepseek-coder
OLLAMA_BASE_URL=http://localhost:11434

# Model routing
FIX_AGENT_MODEL=claude-sonnet
EXPLANATION_AGENT_MODEL=gemini-flash
SECURITY_AGENT_MODEL=gemini-flash
IMPACT_AGENT_MODEL=gemini-flash
